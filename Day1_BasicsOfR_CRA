#Data Types relevant to CRA
# Numeric
age <- 35L                    # integer
income <- 85000.50            # double

# Character
employment_type <- "Salaried"

# Factor (categorical) — critical for WoE/IV binning later
loan_grade <- factor("B", levels = c("A", "B", "C", "D", "E"))
default_flag <- factor(1, levels = c(0, 1),
                       labels = c("Non-Default", "Default"))

cat("\nData Types:\n")
cat("Age (int):", age, "| class:", class(age), "\n")
cat("Income (dbl):", income, "| class:", class(income), "\n")
cat("Employment:", employment_type, "\n")
cat("Loan Grade:", as.character(loan_grade), "\n")
